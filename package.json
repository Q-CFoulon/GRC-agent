{
  "name": "grc-agent",
  "version": "1.0.0",
  "description": "AI-powered GRC (Governance, Risk, Compliance) agent for Teams and Web",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:mcp": "tsx watch src/server/mcp/index.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "preview": "vite preview",
    "start": "node dist/server/index.js",
    "start:mcp": "node dist/server/mcp/index.js",
    "teams-dev": "tsx watch src/server/teams/server.ts",
    "teams-start": "node dist/server/teams/server.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts,.tsx",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "grc",
    "compliance",
    "security",
    "nist",
    "teams",
    "ai",
    "agent",
    "vite"
  ],
  "author": "Security Team",
  "license": "MIT",
  "dependencies": {
    "@azure/openai": "^2.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "botbuilder": "^4.22.0",
    "botbuilder-azure": "^4.22.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
