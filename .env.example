# Azure OpenAI Configuration (Required)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Microsoft Teams Bot Configuration (Optional)
BOT_ID=your-bot-app-id
BOT_PASSWORD=your-bot-password
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password

# Server Configuration
PORT=3000
TEAMS_BOT_PORT=3978
NODE_ENV=development

# Database Configuration (Future)
# DATABASE_URL=postgresql://user:password@localhost:5432/grc_agent

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# API Configuration
API_TIMEOUT=30000
MAX_MESSAGE_LENGTH=4000

# Offline Continuity Store
# Local JSON store used to preserve frameworks, controls, policies, procedures, ingested docs, and exemptions.
GRC_LOCAL_STORE_PATH=./data/grc-local-store.json
